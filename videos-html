<!-- MODAL VIDEO -->
<div class="modal-overlay" id="modal" onclick="cerrarModalClick(event)">
  <div class="modal">
    <div class="modal-head">
      <div class="modal-head-left">
        <span class="modal-cat-tag" id="modal-cat"></span>
        <span class="modal-titulo" id="modal-titulo"></span>
      </div>
      <button class="modal-cerrar" onclick="cerrarModal()">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>
    <div class="video-embed">
      <iframe id="modal-iframe" src="" allowfullscreen allow="autoplay; encrypted-media"></iframe>
    </div>
    <div class="modal-footer">
      <p class="modal-desc-texto" id="modal-desc"></p>
      <div class="modal-actions">
        <button class="btn-compartir" onclick="compartirVideo()">
          <i class="bi bi-share"></i> Compartir
        </button>
        <a class="btn-yt" id="modal-yt" href="#" target="_blank" rel="noopener">
          <i class="bi bi-youtube"></i> YouTube
        </a>
      </div>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- Firebase + lógica -->
<script type="module">
import { db } from './assets/js/firebase-config.js';
import {
  collection, getDocs, query, orderBy
} from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js';

let todos = [];
let filtrados = [];
let catActiva = 'todos';
let videoActual = null;

// ── Carga ───────────────────────────────────────
async function init() {
  try {
    const q = query(collection(db, 'videos_epp'), orderBy('orden','asc'));
    const snap = await getDocs(q);
    todos = snap.docs.map(d => ({ id: d.id, ...d.data() }));
    document.getElementById('estado-cargando').style.display = 'none';
    document.getElementById('stat-total').textContent = todos.length;
    actualizarStats();
    generarFiltros();
    aplicarFiltro('todos');
  } catch(e) {
    document.getElementById('estado-cargando').innerHTML =
      '<i class="bi bi-exclamation-circle"></i><p>Error al cargar. Recarga la página.</p>';
  }
}

function actualizarStats() {
  const cats = new Set(todos.map(v => v.categoria));
  document.getElementById('stat-cats').textContent = cats.size;
  document.getElementById('badge-todos').textContent = todos.length;
}

// ── Filtros dinámicos ───────────────────────────
const iconCat = {
  'Uso general':           'bi-shield-check',
  'Trabajo en altura':     'bi-arrow-up-circle',
  'Protección cabeza':     'bi-emoji-smile',
  'Protección respiratoria':'bi-wind',
  'Protección ocular':     'bi-eye',
  'Protección auditiva':   'bi-ear',
  'Guantes y manos':       'bi-hand-index',
  'Calzado de seguridad':  'bi-boot',
  'Ropa de trabajo':       'bi-person-arms-up',
};

function generarFiltros() {
  const cats = [...new Set(todos.map(v => v.categoria))].sort();
  const wrap = document.getElementById('filtros');
  cats.forEach(cat => {
    const n = todos.filter(v => v.categoria === cat).length;
    const ico = iconCat[cat] || 'bi-tag';
    const btn = document.createElement('button');
    btn.className = 'filtro-btn';
    btn.dataset.cat = cat;
    btn.innerHTML = `<i class="bi ${ico}"></i> ${cat} <span class="count-badge">${n}</span>`;
    btn.onclick = () => activarFiltro(cat, btn);
    wrap.appendChild(btn);
  });
}

window.activarFiltro = function(cat, btn) {
  catActiva = cat;
  document.querySelectorAll('.filtro-btn').forEach(b => b.classList.remove('activo'));
  (btn || document.querySelector(`[data-cat="${cat}"]`))?.classList.add('activo');
  aplicarFiltro(cat);
};

function aplicarFiltro(cat) {
  const busq = document.getElementById('buscador').value.toLowerCase().trim();
  filtrados = (cat === 'todos' ? todos : todos.filter(v => v.categoria === cat))
    .filter(v => !busq || v.titulo?.toLowerCase().includes(busq)
                       || v.descripcion?.toLowerCase().includes(busq)
                       || v.categoria?.toLowerCase().includes(busq));
  ordenarGrid(document.getElementById('sort-select').value, false);
  render();
}

window.buscarVideos = function(val) {
  document.getElementById('btn-clear').style.display = val ? 'block' : 'none';
  aplicarFiltro(catActiva);
};

window.limpiarBusqueda = function() {
  document.getElementById('buscador').value = '';
  document.getElementById('btn-clear').style.display = 'none';
  aplicarFiltro(catActiva);
};

window.ordenarGrid = function(modo, re = true) {
  if (modo === 'recientes') filtrados.sort((a,b) => (b.createdAt?.seconds||0) - (a.createdAt?.seconds||0));
  else if (modo === 'az')    filtrados.sort((a,b) => a.titulo?.localeCompare(b.titulo));
  else                       filtrados.sort((a,b) => (a.orden||99) - (b.orden||99));
  if (re) render();
};

// ── Render ──────────────────────────────────────
function render() {
  const grid  = document.getElementById('grid');
  const vacio = document.getElementById('estado-vacio');
  const cont  = document.getElementById('contador');
  grid.innerHTML = '';
  cont.innerHTML = `<strong>${filtrados.length}</strong> video${filtrados.length !== 1 ? 's' : ''}${catActiva !== 'todos' ? ` en <em>${catActiva}</em>` : ''}`;

  if (!filtrados.length) { vacio.style.display = 'block'; return; }
  vacio.style.display = 'none';

  filtrados.forEach(v => {
    const card = document.createElement('div');
    card.className = 'video-card';
    card.innerHTML = `
      <div class="thumb-wrap">
        <img src="https://img.youtube.com/vi/${v.youtubeId}/mqdefault.jpg"
             alt="${v.titulo}" loading="lazy" onerror="this.style.opacity=0">
        <div class="play-btn"><i class="bi bi-play-fill"></i></div>
        ${v.duracion ? `<span class="duration-badge">${v.duracion}</span>` : ''}
      </div>
      <div class="card-body">
        <span class="cat-tag">
          <i class="bi ${iconCat[v.categoria] || 'bi-tag'}"></i>
          ${v.categoria}
        </span>
        <div class="card-titulo">${v.titulo}</div>
        <div class="card-meta">
          <span class="card-fuente">
            <i class="bi bi-building"></i> ${v.fuente || 'Canal YouTube'}
          </span>
          <span class="btn-ver">Ver <i class="bi bi-arrow-right"></i></span>
        </div>
      </div>
    `;
    card.onclick = () => abrirModal(v);
    grid.appendChild(card);
  });
}

// ── Modal ───────────────────────────────────────
window.abrirModal = function(v) {
  videoActual = v;
  document.getElementById('modal-cat').textContent   = v.categoria;
  document.getElementById('modal-titulo').textContent = v.titulo;
  document.getElementById('modal-desc').textContent   = v.descripcion || '';
  document.getElementById('modal-iframe').src =
    `https://www.youtube.com/embed/${v.youtubeId}?autoplay=1&rel=0`;
  document.getElementById('modal-yt').href =
    `https://www.youtube.com/watch?v=${v.youtubeId}`;
  document.getElementById('modal').classList.add('abierto');
  document.body.style.overflow = 'hidden';
};

window.cerrarModal = function() {
  document.getElementById('modal').classList.remove('abierto');
  document.getElementById('modal-iframe').src = '';
  document.body.style.overflow = '';
  videoActual = null;
};

window.cerrarModalClick = function(e) {
  if (e.target === document.getElementById('modal')) cerrarModal();
};

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') cerrarModal();
});

// ── Compartir ───────────────────────────────────
window.compartirVideo = function() {
  if (!videoActual) return;
  const url = `https://www.youtube.com/watch?v=${videoActual.youtubeId}`;
  if (navigator.share) {
    navigator.share({ title: videoActual.titulo, url });
  } else {
    navigator.clipboard.writeText(url).then(() => mostrarToast('¡Enlace copiado al portapapeles!'));
  }
};

// ── Kary ────────────────────────────────────────
window.abrirKary = function() {
  const karyBtn = document.getElementById('karyBtn');
  if (karyBtn) { karyBtn.click(); return; }
  window.location.href = 'index.html#kary';
};

// ── Sugerir video ───────────────────────────────
window.sugerirVideo = function() {
  mostrarToast('Próximamente: formulario para sugerir videos 🎬');
};

// ── Toast ────────────────────────────────────────
function mostrarToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('visible');
  setTimeout(() => t.classList.remove('visible'), 2800);
}

init();
</script>

</body>
</html>
