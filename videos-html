    <div class="hero-stat"><strong>100%</strong><span>Gratuitos</span></div>
  </div>
</section>

<!-- CONTENIDO PRINCIPAL -->
<main class="main">

  <!-- FILTROS -->
  <div class="filtros-wrap">
    <div class="filtros" id="filtros">
      <button class="filtro-btn activo" data-cat="todos" onclick="activarFiltro('todos', this)">
        <i class="bi bi-grid-3x3-gap"></i> Todos
        <span class="count-badge" id="badge-todos">—</span>
      </button>
      <!-- Filtros dinámicos se agregan desde JS -->
    </div>
    <select class="sort-select" id="sort-select" onchange="ordenarGrid(this.value)">
      <option value="orden">Orden recomendado</option>
      <option value="recientes">Más recientes</option>
      <option value="az">A → Z</option>
    </select>
  </div>

  <!-- RESULTADO -->
  <div class="resultado-bar">
    <div class="contador" id="contador">Cargando…</div>
  </div>

  <!-- ESTADOS -->
  <div class="estado" id="estado-cargando">
    <i class="bi bi-arrow-repeat"></i>
    <p>Cargando videos…</p>
  </div>
  <div class="estado" id="estado-vacio">
    <i class="bi bi-camera-video-off"></i>
    <p>No hay videos para esta búsqueda.<br>Intenta con otro término o categoría.</p>
