  </a>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-badge">
    <i class="bi bi-play-circle-fill"></i>
    Biblioteca de Videos EPP
  </div>
  <h1>Aprende a usar tu EPP<br>de forma correcta</h1>
  <p>Videos educativos de fuentes chilenas: ACHS, ISP y especialistas en prevención de riesgos laborales.</p>

  <!-- Buscador -->
  <div class="search-wrap">
    <i class="bi bi-search search-icon"></i>
    <input type="text" id="buscador" placeholder="Buscar por tipo de EPP, riesgo o industria…" oninput="buscarVideos(this.value)">
    <button class="search-clear" id="btn-clear" onclick="limpiarBusqueda()">
      <i class="bi bi-x-circle-fill"></i>
    </button>
  </div>

  <!-- Stats -->
  <div class="hero-stats" id="hero-stats">
    <div class="hero-stat"><strong id="stat-total">—</strong><span>Videos disponibles</span></div>
