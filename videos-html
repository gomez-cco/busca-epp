  <!-- GRID -->
  <div class="grid" id="grid"></div>

  <!-- BANNER SUGERIR VIDEO -->
  <div class="banner-sugerir">
    <p><strong>¿Conoces un buen video sobre EPP?</strong><br>
    Ayúdanos a crecer la biblioteca sugiriendo contenido educativo de calidad.</p>
    <button class="btn-sugerir" onclick="sugerirVideo()">
      <i class="bi bi-plus-circle"></i> Sugerir video
    </button>
  </div>

  <!-- CTA KARY -->
  <div class="cta-kary">
    <div class="kary-avatar">👩‍💼</div>
    <div style="flex:1">
      <h3>¿No sabes qué EPP necesitas?</h3>
      <p>Kary, nuestra asistente virtual, te ayuda a identificar el equipo correcto según tu industria y tipo de riesgo. Gratis, sin registro.</p>
      <button class="btn-kary" onclick="abrirKary()">
        <i class="bi bi-chat-dots-fill"></i> Pregúntale a Kary
      </button>
    </div>
  </div>

</main>

